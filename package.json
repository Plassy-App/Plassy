{
  "name": "plassy-workspace",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "prepare": "husky",
    "help": "bun scripts/workspace-help.mjs",
    "dev:app": "bun run app:start:dev",
    "dev:backend": "bun run backend:dev",
    "dev:scraper": "bun run scraper:dev",
    "dev:web": "bun run frontend:dev",
    "format": "prettier --write . --ignore-path .prettierignore",
    "lint": "bun run app:lint && bun run backend:lint && bun run contracts:lint && bun run frontend:lint && bun run scraper:lint",
    "typecheck": "bun run contracts:typecheck && bun run backend:typecheck && bun run scraper:typecheck && cd plassy-frontend && bunx tsc --noEmit",
    "test": "bun run app:test && bun run backend:test",
    "app:start": "cd plassy-app && bunx expo start",
    "app:start:dev": "cd plassy-app && bunx expo start --dev-client",
    "app:lint": "cd plassy-app && bunx expo lint",
    "app:test": "cd plassy-app && bunx jest",
    "backend:dev": "cd plassy-backend && bun --watch src/index.ts",
    "backend:start": "cd plassy-backend && bun src/index.ts",
    "backend:build": "cd plassy-backend && bunx prisma generate && bunx tsc --noEmit",
    "backend:lint": "cd plassy-backend && bunx eslint src",
    "backend:typecheck": "cd plassy-backend && bunx tsc --noEmit",
    "backend:test": "cd plassy-backend && bunx jest",
    "backend:db:generate": "cd plassy-backend && bunx prisma generate",
    "backend:db:migrate": "cd plassy-backend && bunx prisma migrate dev",
    "backend:db:push": "cd plassy-backend && bunx prisma db push",
    "backend:db:studio": "cd plassy-backend && bunx prisma studio",
    "contracts:build": "cd plassy-contracts && bunx tsc -p tsconfig.json",
    "contracts:typecheck": "cd plassy-contracts && bunx tsc --noEmit",
    "contracts:lint": "cd plassy-contracts && bunx eslint src",
    "frontend:dev": "cd plassy-frontend && bunx next dev",
    "frontend:build": "cd plassy-frontend && bunx next build",
    "frontend:start": "cd plassy-frontend && bunx next start",
    "frontend:lint": "cd plassy-frontend && bunx eslint .",
    "scraper:dev": "cd plassy-scraper && bun --watch src/index.ts",
    "scraper:start": "cd plassy-scraper && bun src/index.ts",
    "scraper:typecheck": "cd plassy-scraper && bunx tsc --noEmit",
    "scraper:lint": "cd plassy-scraper && bunx eslint src"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "3.8.3",
    "tailwindcss": "^4.2.4"
  }
}
